{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-desktop-read",
    "fs:allow-download-read",
    "fs:allow-home-read",
    "fs:allow-applocaldata-write-recursive",
    "fs:allow-applocaldata-read-recursive",
    "fs:allow-app-write",
    "sql:default",
    {
      "identifier": "sql:allow-execute",
      "allow": [
        "sqlite:speaking_app.db"
      ]
    },
    {
      "identifier": "sql:allow-select",
      "allow": [
        "sqlite:speaking_app.db"
      ]
    },
    {
      "identifier": "sql:allow-load",
      "allow": [
        "sqlite:speaking_app.db"
      ]
    }
  ]
}
